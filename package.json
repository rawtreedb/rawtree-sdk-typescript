{
  "name": "@rawtree/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building apps with RawTree.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./monitoring": {
      "types": "./dist/monitoring.d.ts",
      "import": "./dist/monitoring.js"
    },
    "./integrations/ai-sdk": {
      "types": "./dist/integrations/ai-sdk.d.ts",
      "import": "./dist/integrations/ai-sdk.js"
    },
    "./integrations/daytona": {
      "types": "./dist/integrations/daytona.d.ts",
      "import": "./dist/integrations/daytona.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "rawtree",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "ai": "^6.0.204 || ^7.0.0-0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.71",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.3",
    "ai": "^6.0.204",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0"
  }
}
